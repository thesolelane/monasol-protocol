# ─── Contracts ───────────────────────────────────────────────
# Deployer wallet private key — never commit the real value
DEPLOYER_PRIVATE_KEY=0x

# Oracle hot wallet address — signs guardian attestations
# Falls back to DEPLOYER_PRIVATE_KEY wallet if not set
ORACLE_SIGNER_ADDRESS=0x

# Monad testnet RPC endpoint
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# ─── API server ──────────────────────────────────────────────
# Supabase PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/db

# Runtime environment
NODE_ENV=development

# Log verbosity
LOG_LEVEL=info
