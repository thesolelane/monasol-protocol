# ── Contracts ─────────────────────────────────────────────────────────────────
# Private key of the wallet that will deploy contracts (0x-prefixed)
DEPLOYER_PRIVATE_KEY=

# Address of the oracle hot wallet that signs verifyAccess proofs
# Falls back to deployer address if not set
ORACLE_SIGNER_ADDRESS=

# Monad testnet RPC — defaults to public endpoint if not set
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# ── API Server ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/monasol

NODE_ENV=development
LOG_LEVEL=info
